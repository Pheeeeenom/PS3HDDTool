<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PS3HddTool.Avalonia.ViewModels"
        xmlns:models="using:PS3HddTool.Core.Models"
        x:Class="PS3HddTool.Avalonia.Views.MainWindow"
        Title="PS3 HDD Tool"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#050508"
        Icon="/Assets/icon.png">

    <Window.Styles>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- PS3 FAT — XrossMediaBar inspired theme                     -->
        <!-- Deep black, signature blue chrome, subtle glow accents     -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- Section headers: uppercase, tracked, blue -->
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4070A0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="LetterSpacing" Value="2.5"/>
        </Style>

        <!-- Cards: near-black with blue-tinted border -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#09090F"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderBrush" Value="#14142A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Primary button: PS3 chrome blue -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#003D80"/>
            <Setter Property="Foreground" Value="#B0C8E8"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="BorderBrush" Value="#005AAA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#005AAA"/>
            <Setter Property="Foreground" Value="#E0ECF8"/>
            <Setter Property="BorderBrush" Value="#0070CC"/>
        </Style>
        <Style Selector="Button.primary:pressed">
            <Setter Property="Background" Value="#002D60"/>
        </Style>

        <!-- Default button: dark chrome -->
        <Style Selector="Button">
            <Setter Property="Background" Value="#0C0C18"/>
            <Setter Property="Foreground" Value="#7888A0"/>
            <Setter Property="BorderBrush" Value="#1C1C34"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#14142A"/>
            <Setter Property="Foreground" Value="#A0B0C8"/>
            <Setter Property="BorderBrush" Value="#252546"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#08080F"/>
        </Style>

        <!-- Danger button -->
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#200810"/>
            <Setter Property="Foreground" Value="#C04050"/>
            <Setter Property="BorderBrush" Value="#381020"/>
        </Style>
        <Style Selector="Button.danger:pointerover">
            <Setter Property="Background" Value="#301018"/>
            <Setter Property="Foreground" Value="#E06070"/>
        </Style>

        <!-- TextBox: deep recessed input -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#040408"/>
            <Setter Property="Foreground" Value="#90A0B8"/>
            <Setter Property="BorderBrush" Value="#14142A"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#004488"/>
        </Style>
        <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
            <Setter Property="Foreground" Value="#282840"/>
        </Style>

        <!-- CheckBox -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#506070"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- TreeView: transparent, custom selection -->
        <Style Selector="TreeView">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TreeViewItem">
            <Setter Property="Foreground" Value="#8898B0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>
        <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="#0C2848"/>
            <Setter Property="CornerRadius" Value="3"/>
        </Style>
        <Style Selector="TreeViewItem:selected">
            <Setter Property="Foreground" Value="#C0D4F0"/>
        </Style>

        <!-- ListBox: log viewer -->
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="MinHeight" Value="18"/>
        </Style>

        <!-- ProgressBar: PS3 blue -->
        <Style Selector="ProgressBar">
            <Setter Property="Background" Value="#0A0A18"/>
            <Setter Property="Foreground" Value="#005AAA"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="MinHeight" Value="6"/>
        </Style>

        <!-- Separator -->
        <Style Selector="Border.sep-v">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Background" Value="#14142A"/>
            <Setter Property="Margin" Value="6,4"/>
        </Style>

        <!-- Scrollbar thin style -->
        <Style Selector="ScrollViewer /template/ ScrollBar">
            <Setter Property="Width" Value="6"/>
        </Style>

    </Window.Styles>

    <Grid RowDefinitions="4,Auto,*,Auto,Auto">

        <!-- ═══ Row 0: Chrome accent strip ═══ -->
        <Border Grid.Row="0" IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#001030" Offset="0"/>
                    <GradientStop Color="#003880" Offset="0.2"/>
                    <GradientStop Color="#0060BB" Offset="0.4"/>
                    <GradientStop Color="#0080DD" Offset="0.5"/>
                    <GradientStop Color="#0060BB" Offset="0.6"/>
                    <GradientStop Color="#003880" Offset="0.8"/>
                    <GradientStop Color="#001030" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- ═══ Row 1: Header bar ═══ -->
        <Border Grid.Row="1" Padding="16,10" BorderThickness="0,0,0,1" BorderBrush="#0C0C1A">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0A0A14" Offset="0"/>
                    <GradientStop Color="#070710" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*">

                <!-- Row 0: Brand + source buttons + disk status -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto" Margin="0,0,0,10">

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock Text="PS3" FontSize="24" FontWeight="Bold" Foreground="#005AAA"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Text=" HDD TOOL" FontSize="18" FontWeight="Light" Foreground="#384858"
                                   LetterSpacing="3" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                    </StackPanel>

                    <!-- Action buttons -->
                    <Button Grid.Column="1" Content="Open Image" Click="OnOpenImage" Classes="primary"
                            IsEnabled="{Binding !IsBusy}" Margin="0,0,4,0"/>
                    <Button Grid.Column="2" Content="Open Drive" Click="OnOpenPhysicalDrive" Classes="primary"
                            IsEnabled="{Binding !IsBusy}" Margin="0,0,4,0"/>
                    <Button Grid.Column="3" Content="Extract PKG" Click="OnExtractPkg"
                            IsEnabled="{Binding !IsBusy}" Margin="0,0,4,0"/>

                    <!-- Spacer -->
                    <Panel Grid.Column="4"/>

                    <!-- Disk status -->
                    <TextBlock Grid.Column="5" Text="{Binding DiskInfo.Source, FallbackValue='No disk loaded'}"
                               VerticalAlignment="Center" Foreground="#303848" FontSize="11"
                               FontFamily="Consolas,Courier New,monospace" Margin="0,0,12,0"/>

                    <Border Classes="sep-v" Grid.Column="6"/>

                    <Button Grid.Column="7" Content="About" Click="OnAbout" VerticalAlignment="Center"/>
                </Grid>

                <!-- Row 1: Key entry -->
                <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto" VerticalAlignment="Center">
                    <Button Grid.Column="0" Content="Keys" Click="OnSavedKeys"
                            Margin="0,0,4,0" ToolTip.Tip="Load a saved EID Root Key"/>
                    <Button Grid.Column="1" Content="Import" Click="OnImportKey"
                            Margin="0,0,4,0" ToolTip.Tip="Import eid_root_key.bin, hdd_key.bin, or individual ATA key files (select two for data+tweak pair)"/>
                    <Button Grid.Column="2" Content="Export" Click="OnExportKeys"
                            Margin="0,0,8,0" ToolTip.Tip="Derive and export key files (ata_data_key.bin, hdd_key.bin, etc.) from EID Root Key"/>
                    <TextBlock Text="ENCRYPTION KEY" VerticalAlignment="Center" Margin="0,0,10,0" Grid.Column="3"
                               Foreground="#304060" FontSize="10" FontWeight="Bold" LetterSpacing="1.5"/>
                    <TextBox Grid.Column="4" Text="{Binding EidRootKeyHex}"
                             Watermark="EID root key (96 hex), or use Import for hdd_key.bin / ata_data_key.bin"
                             FontFamily="Consolas,Courier New,monospace" FontSize="11"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="5" Content="Save" Click="OnSaveKey"
                            Margin="0,0,6,0"
                            ToolTip.Tip="Save current key with a nickname"/>
                    <Button Grid.Column="6" Content="Decrypt" Click="OnDecrypt" Classes="primary"
                            IsEnabled="{Binding IsDiskOpen}"/>
                </Grid>

                <!-- Row 2: Write action bar (only when mounted) -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Margin="0,10,0,0"
                            IsVisible="{Binding IsFilesystemMounted}">
                    <Button Content="Create Directory" Click="OnCreateDirectory"/>
                    <Button Content="Copy File" Click="OnCopyFileToPs3"/>
                    <Button Content="Copy Folder" Click="OnCopyFolderToPs3"/>
                    <Border Classes="sep-v"/>
                    <Button Content="Extract" Click="OnExtract" Classes="primary"
                            IsEnabled="{Binding SelectedNode, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <Button Content="Rename" Click="OnRename"
                            IsEnabled="{Binding SelectedNode, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <Button Content="Delete" Click="OnDeleteSelected" Classes="danger"
                            IsEnabled="{Binding SelectedNode, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <Border Classes="sep-v"/>
                    <CheckBox Content="Fake Write" IsChecked="{Binding DryRunMode}" Margin="0,2,0,0"/>
                    <CheckBox Content="Verbose" IsChecked="{Binding VerboseDiagnostics}" Margin="0,2,0,0"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ═══ Row 2: Main split view ═══ -->
        <Grid Grid.Row="2" ColumnDefinitions="320,1,*" Margin="0">

            <!-- LEFT: Filesystem tree -->
            <Border Grid.Column="0" Background="#07070D" Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="16,12,16,8" BorderThickness="0,0,0,1" BorderBrush="#0E0E1C">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="header" Text="FILESYSTEM" Margin="0"/>
                            <!-- Partition count badge -->
                            <Border Grid.Column="1" Background="#0C1828" CornerRadius="8"
                                    Padding="8,2" IsVisible="{Binding IsDecrypted}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding Partitions.Count, StringFormat='{}{0} partitions'}"
                                           FontSize="10" Foreground="#406080"/>
                            </Border>
                        </Grid>
                    </Border>

                    <TreeView Grid.Row="1" ItemsSource="{Binding FileTree}"
                              SelectedItem="{Binding SelectedNode}"
                              Name="FileTreeView" Margin="4,4">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="2,2">
                                    <TextBlock Text="{Binding Icon}" FontSize="13" VerticalAlignment="Center"
                                               Grid.Column="0" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"
                                               Grid.Column="1" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding SizeFormatted}" FontSize="9"
                                               Foreground="#283040" VerticalAlignment="Center"
                                               Grid.Column="2" Margin="8,0,4,0"
                                               FontFamily="Consolas,Courier New,monospace"/>
                                </Grid>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Divider -->
            <Border Grid.Column="1" Background="#0E0E1C"/>

            <!-- RIGHT: Details panel -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*">

                <!-- Partition Info (collapsible) -->
                <Border Grid.Row="0" IsVisible="{Binding IsDecrypted}" Padding="20,14,20,10"
                        Background="#08080E" BorderThickness="0,0,0,1" BorderBrush="#0E0E1C">
                    <ItemsControl ItemsSource="{Binding Partitions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0A0A14" CornerRadius="4" Padding="14,8"
                                        BorderBrush="#14142A" BorderThickness="1">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#8898B0"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding SizeFormatted}" FontSize="10"
                                                       Foreground="#384858" FontFamily="Consolas,Courier New,monospace"/>
                                            <TextBlock Text="{Binding Type}" FontSize="10" Foreground="#204060"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- File details -->
                <Border Grid.Row="1" Padding="24,20" Background="#07070D">
                    <Grid RowDefinitions="*">
                        <!-- Has selection -->
                        <StackPanel Spacing="12"
                                    IsVisible="{Binding SelectedNode, Converter={x:Static ObjectConverters.IsNotNull}}">

                            <!-- File info card -->
                            <Border Background="#0A0A12" CornerRadius="4" Padding="20,16"
                                    BorderBrush="#14142A" BorderThickness="1">

                                <!-- Blue accent on left edge -->
                                <Border.Styles>
                                    <Style Selector="Border.info-card">
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                        <Setter Property="BorderBrush" Value="#003D80"/>
                                    </Style>
                                </Border.Styles>

                                <Grid ColumnDefinitions="90,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" >
                                    <TextBlock Text="NAME" Foreground="#304060" Grid.Row="0"
                                               FontSize="10" FontWeight="Bold" LetterSpacing="1" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding SelectedNode.Name}" Grid.Row="0" Grid.Column="1"
                                               FontWeight="SemiBold" Foreground="#C0D4F0" FontSize="14"/>

                                    <TextBlock Text="PATH" Foreground="#304060" Grid.Row="1"
                                               FontSize="10" FontWeight="Bold" LetterSpacing="1" Margin="0,8,0,2"/>
                                    <TextBlock Text="{Binding SelectedNode.FullPath}" Grid.Row="1" Grid.Column="1"
                                               FontFamily="Consolas,Courier New,monospace" FontSize="11"
                                               Foreground="#506880" Margin="0,8,0,0"/>

                                    <TextBlock Text="SIZE" Foreground="#304060" Grid.Row="2"
                                               FontSize="10" FontWeight="Bold" LetterSpacing="1" Margin="0,8,0,2"/>
                                    <TextBlock Text="{Binding SelectedNode.SizeFormatted}" Grid.Row="2" Grid.Column="1"
                                               Foreground="#8898B0" FontSize="12" Margin="0,8,0,0"/>

                                    <TextBlock Text="MODIFIED" Foreground="#304060" Grid.Row="3"
                                               FontSize="10" FontWeight="Bold" LetterSpacing="1" Margin="0,8,0,2"/>
                                    <TextBlock Text="{Binding SelectedNode.Modified}" Grid.Row="3" Grid.Column="1"
                                               Foreground="#8898B0" FontSize="12" Margin="0,8,0,0"/>

                                    <TextBlock Text="MODE" Foreground="#304060" Grid.Row="4"
                                               FontSize="10" FontWeight="Bold" LetterSpacing="1" Margin="0,8,0,2"/>
                                    <TextBlock Text="{Binding SelectedNode.Permissions}" Grid.Row="4" Grid.Column="1"
                                               FontFamily="Consolas,Courier New,monospace"
                                               Foreground="#506880" FontSize="11" Margin="0,8,0,0"/>
                                </Grid>
                            </Border>

                            <!-- Image preview -->
                            <Border CornerRadius="4" ClipToBounds="True"
                                    IsVisible="{Binding HasImagePreview}" MaxHeight="320"
                                    Background="#04040A" BorderBrush="#14142A" BorderThickness="1">
                                <Image Source="{Binding ImagePreview}" Stretch="Uniform"
                                       MaxHeight="300" Margin="8"/>
                            </Border>
                        </StackPanel>

                        <!-- No selection -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8"
                                    IsVisible="{Binding SelectedNode, Converter={x:Static ObjectConverters.IsNull}}">
                            <TextBlock Text="📁" FontSize="32" HorizontalAlignment="Center" Opacity="0.15"/>
                            <TextBlock Text="Select a file or folder" Foreground="#1A1A30"
                                       FontSize="13" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══ Row 3: Log panel ═══ -->
        <Border Grid.Row="3" MaxHeight="150" Background="#06060C"
                BorderThickness="0,1,0,0" BorderBrush="#0E0E1C">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Padding="16,8,16,6" BorderThickness="0,0,0,1" BorderBrush="#0A0A16">
                    <TextBlock Classes="header" Text="LOG" Margin="0"/>
                </Border>
                <ListBox Grid.Row="1" ItemsSource="{Binding LogMessages}" Name="LogList"
                         FontFamily="Consolas,Courier New,monospace" FontSize="10"
                         Background="Transparent" Margin="8,2">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#303848"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ═══ Row 4: Status bar ═══ -->
        <Border Grid.Row="4" Padding="16,6" BorderThickness="0,1,0,0" BorderBrush="#0A0A16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#08080F" Offset="0"/>
                    <GradientStop Color="#050508" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Text="{Binding StatusText}" Foreground="#304060"
                           VerticalAlignment="Center" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="{Binding ProgressText}" Foreground="#0070CC"
                           VerticalAlignment="Center" Margin="16,0" FontSize="11"
                           FontFamily="Consolas,Courier New,monospace"
                           IsVisible="{Binding IsBusy}"/>
                <ProgressBar Grid.Column="2" Width="180" Height="6"
                             IsVisible="{Binding IsBusy}"
                             Minimum="0" Maximum="100"
                             Value="{Binding ProgressValue}"
                             IsIndeterminate="{Binding IsProgressIndeterminate}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
